flowchart LR
  SCH("<b>Every 30 Minutes</b><br/>Schedule Trigger"):::webhook
  GC("<b>Get FB Conversations</b><br/>Graph API"):::base
  CP("<b>Check Pending Payments</b><br/>Code · finds chats missing a<br/>noted-payment reply in 72h"):::base
  HP("<b>Has Pending Payments</b><br/>If"):::logic
  AL("<b>Send Numbered Alert</b><br/>Telegram"):::base

  TGD("<b>Telegram Done Trigger</b><br/>manager replies done N or done all"):::webhook
  HD("<b>Handle Done Reply</b><br/>Code · acknowledge + dismiss"):::base
  RC("<b>Reply Done Confirmation</b><br/>Telegram"):::base

  SCH --> GC --> CP --> HP
  HP -->|"Yes"| AL
  TGD --> HD --> RC

  classDef webhook    fill:#f9d0c4,stroke:#e06666,stroke-width:2px
  classDef logic      fill:#cfe2f3,stroke:#3d85c6,stroke-width:1px
  classDef base       fill:#d9ead3,stroke:#6aa84f,stroke-width:1px
